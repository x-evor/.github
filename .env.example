# Local-only environment template (no real secrets here)
# Copy to .env and fill with local values.

# SSH / remote ops (mcp-ssh-manager server list)
SSH_SERVER_OBSERVABILITY_HOST=
SSH_SERVER_OBSERVABILITY_USER=root
SSH_SERVER_OBSERVABILITY_KEYPATH=~/.ssh/id_rsa
SSH_SERVER_OBSERVABILITY_PORT=22
SSH_SERVER_OBSERVABILITY_DESCRIPTION=

SSH_SERVER_POSTGRESQL_HOST=
SSH_SERVER_POSTGRESQL_USER=root
SSH_SERVER_POSTGRESQL_KEYPATH=~/.ssh/id_rsa
SSH_SERVER_POSTGRESQL_PORT=22
SSH_SERVER_POSTGRESQL_DESCRIPTION=

SSH_SERVER_US_XHTTP_HOST=
SSH_SERVER_US_XHTTP_USER=root
SSH_SERVER_US_XHTTP_KEYPATH=~/.ssh/id_rsa
SSH_SERVER_US_XHTTP_PORT=22
SSH_SERVER_US_XHTTP_DESCRIPTION=

SSH_SERVER_HK_XHTTP_HOST=
SSH_SERVER_HK_XHTTP_USER=root
SSH_SERVER_HK_XHTTP_KEYPATH=~/.ssh/id_rsa
SSH_SERVER_HK_XHTTP_PORT=22
SSH_SERVER_HK_XHTTP_DESCRIPTION=

SSH_SERVER_JP_XHTTP_HOST=
SSH_SERVER_JP_XHTTP_USER=root
SSH_SERVER_JP_XHTTP_KEYPATH=~/.ssh/id_rsa
SSH_SERVER_JP_XHTTP_PORT=22
SSH_SERVER_JP_XHTTP_DESCRIPTION=

# Database / admin bootstrap
POSTGRES_USER=
POSTGRES_PASSWORD=
SUPERADMIN_PASSWORD=

# Service-to-service auth
INTERNAL_SERVICE_TOKEN=

# GitOps / Flux bootstrap auth
# Leave blank or set to `public` for public repos.
# Private repos can use `https-basic`, `https-bearer`, or `ssh`.
GITOPS_REPO=
GITOPS_AUTH_MODE=
VAULT_URL=
VAULT_NAMESPACE=
GITOPS_FLUX_DEPLOY_KEY=
GITOPS_FLUX_DEPLOY_KEY_PUB=
GITOPS_FLUX_HTTP_USERNAME=x-access-token
GITOPS_FLUX_HTTP_PASSWORD=
GITOPS_FLUX_TOKEN=
GITOPS_FLUX_BEARER_TOKEN=

# MCP / tooling
CODEX_GITHUB_PERSONAL_ACCESS_TOKEN=
WEB_SITE_MCP_ACCESS_TOKEN=

# Cloud dev desktop control plane
AZURE_SUBSCRIPTION_ID=
AZURE_WINDOWS_ADMIN_PASSWORD=
GCP_PROJECT_ID=
GCP_WINDOWS_ADMIN_PASSWORD=
CLOUD_DEV_DESKTOP_WINDOWS_PASSWORD=
