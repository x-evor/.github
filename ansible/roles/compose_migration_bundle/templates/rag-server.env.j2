{% for key, value in compose_migration_rag_env.items() if key != 'DATABASE_URL' %}
{{ key }}={{ value }}
{% endfor %}
{% if compose_migration_rag_env.POSTGRES_USER is not defined %}
POSTGRES_USER={{ compose_migration_rag_env.DB_USER | default('postgres') }}
{% endif %}
{% if compose_migration_rag_env.POSTGRES_PASSWORD is not defined %}
POSTGRES_PASSWORD={{ compose_migration_rag_env.DB_PASSWORD | default('REPLACE_ME') }}
{% endif %}
{% if compose_migration_rag_env.POSTGRES_DB is not defined %}
POSTGRES_DB={{ compose_migration_rag_env.DB_NAME | default('knowledge_db') }}
{% endif %}
{% if compose_migration_rag_env.DATABASE_URL is defined and compose_migration_rag_env.DATABASE_URL not in ['', 'REPLACE_ME'] %}
DATABASE_URL={{ compose_migration_rag_env.DATABASE_URL }}
{% else %}
DATABASE_URL=postgres://{{ compose_migration_rag_env.DB_USER | default('postgres') }}:{{ compose_migration_rag_env.DB_PASSWORD | default('REPLACE_ME') }}@stunnel-client:15432/{{ compose_migration_rag_env.DB_NAME | default('knowledge_db') }}?sslmode=disable
{% endif %}
