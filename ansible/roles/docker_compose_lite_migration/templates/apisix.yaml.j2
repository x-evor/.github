routes:
  - id: 1
    uri: "/*"
    hosts:
      - accounts.svc.plus
    name: stable-accounts
    upstream:
      type: roundrobin
      nodes:
        "accounts:8080": 1

  - id: 2
    uri: "/*"
    hosts:
      - preview-accounts.svc.plus
    name: preview-accounts
    upstream:
      type: roundrobin
      nodes:
        "accounts:8080": 1

  - id: 3
    uri: "/*"
    hosts:
      - rag-server.svc.plus
    name: stable-rag-server
    upstream:
      type: roundrobin
      nodes:
        "rag-server:8080": 1

#END
