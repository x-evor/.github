{% for key, value in docker_compose_lite_rag_env.items() if key != 'DATABASE_URL' %}
{{ key }}={{ value }}
{% endfor %}
{% if docker_compose_lite_rag_env.POSTGRES_USER is not defined %}
POSTGRES_USER={{ docker_compose_lite_rag_env.DB_USER | default('postgres') }}
{% endif %}
{% if docker_compose_lite_rag_env.POSTGRES_PASSWORD is not defined %}
POSTGRES_PASSWORD={{ docker_compose_lite_rag_env.DB_PASSWORD | default('REPLACE_ME') }}
{% endif %}
{% if docker_compose_lite_rag_env.POSTGRES_DB is not defined %}
POSTGRES_DB={{ docker_compose_lite_rag_env.DB_NAME | default('knowledge_db') }}
{% endif %}
{% if docker_compose_lite_rag_env.DATABASE_URL is defined and docker_compose_lite_rag_env.DATABASE_URL not in ['', 'REPLACE_ME'] %}
DATABASE_URL={{ docker_compose_lite_rag_env.DATABASE_URL }}
{% else %}
DATABASE_URL=postgres://{{ docker_compose_lite_rag_env.DB_USER | default('postgres') }}:{{ docker_compose_lite_rag_env.DB_PASSWORD | default('REPLACE_ME') }}@stunnel-client:15432/{{ docker_compose_lite_rag_env.DB_NAME | default('knowledge_db') }}?sslmode=disable
{% endif %}
