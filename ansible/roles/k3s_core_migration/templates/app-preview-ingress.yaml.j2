apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ manifest.service.name }}-preview
  namespace: {{ manifest.service.namespace }}
  annotations:
    kubernetes.io/ingress.class: apisix
    cert-manager.io/cluster-issuer: {{ k3s_core_cluster_issuer }}
    external-dns.alpha.kubernetes.io/hostname: {{ manifest.service.preview_host }}
spec:
  tls:
    - hosts:
        - {{ manifest.service.preview_host }}
      secretName: {{ manifest.service.name }}-preview-tls
  rules:
    - host: {{ manifest.service.preview_host }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: {{ manifest.service.name }}-preview
                port:
                  number: 80
