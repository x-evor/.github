apiVersion: v1
kind: ConfigMap
metadata:
  name: stunnel-client-config
  namespace: {{ k3s_core_shared_stunnel.namespace }}
data:
  stunnel.conf: |
    foreground = yes
    pid = /tmp/stunnel.pid
    [postgres-client]
    client = yes
    accept = 0.0.0.0:{{ k3s_core_shared_stunnel.accept_port }}
    connect = {{ k3s_core_shared_stunnel.host }}:{{ k3s_core_shared_stunnel.port }}
    verify = 2
    CAfile = /etc/ssl/certs/ca-certificates.crt
    checkHost = {{ k3s_core_shared_stunnel.host }}
