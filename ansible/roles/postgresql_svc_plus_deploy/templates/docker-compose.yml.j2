services:
  postgres:
    image: {{ postgresql_release_image | to_json }}
    container_name: {{ postgresql_release_container_name | to_json }}
    restart: unless-stopped
    environment:
      POSTGRES_USER: {{ postgresql_release_user | to_json }}
      POSTGRES_PASSWORD: {{ postgresql_release_password | to_json }}
      POSTGRES_DB: {{ postgresql_release_database | to_json }}
      PGDATA: /var/lib/postgresql/data/pgdata
    command:
      - postgres
      - -c
      - config_file=/etc/postgresql/postgresql.conf
    ports:
      - "127.0.0.1:{{ postgresql_release_local_port }}:5432"
    volumes:
      - {{ postgresql_release_data_dir | to_json }}:/var/lib/postgresql/data
      - {{ (postgresql_release_conf_dir ~ '/postgresql.conf') | to_json }}:/etc/postgresql/postgresql.conf:ro
    healthcheck:
      test:
        - CMD-SHELL
        - pg_isready -U {{ postgresql_release_user | quote }} -h 127.0.0.1
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

